{
  "productName": "NextERP",
  "version": "0.1.0",
  "identifier": "com.tactidev.next-erp",
  "build": {
    "beforeBuildCommand": "npm run build && node scripts/copy-standalone.js",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "NextERP — Business Management Platform",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
