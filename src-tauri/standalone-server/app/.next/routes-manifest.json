  "dynamicRoutes": [
    {
      "page": "/accounting/invoices/[id]",
      "regex": "^/accounting/invoices/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/accounting/invoices/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/projects/[id]",
      "regex": "^/projects/([^/]+?)(?:/)?$",
